<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>net.gapul.keystats.gui</string>
  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/Applications/Keystats.app/Contents/MacOS/KeystatsGUI</string>
    <string>--background</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <false/>
  <key>LimitLoadToSessionType</key>
  <string>Aqua</string>
  <!-- GUI も同じ DB を読むよう XDG を明示 -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>XDG_DATA_HOME</key><string>__DATA__</string>
    <key>XDG_STATE_HOME</key><string>__STATE__</string>
  </dict>
</dict>
</plist>
