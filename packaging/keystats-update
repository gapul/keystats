#!/usr/bin/env bash
# keystats 自己アップデータ。GitHub Releases の最新版を見て、新しければ
# 「今この keystats-update が入っているアプリ自身」をその場で差し替える。
# 設置先(/Applications でも ~/Applications でも)に追従。依存なし(curl/plutil/ditto)。
#   keystats-update            … 新しければ更新
#   keystats-update --check    … 確認だけ(exit 10 = 更新あり)
set -euo pipefail

REPO="gapul/keystats"
API="https://api.github.com/repos/$REPO/releases/latest"
MODE="${1:-}"
# 自分の位置(.../Keystats.app/Contents/Resources/keystats-update)からアプリのパスを導出
APP="$(cd "$(dirname "$0")/../.." && pwd)"

notify() { osascript -e "display notification \"$2\" with title \"$1\"" >/dev/null 2>&1 || true; }
ver_ge() { [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)" = "$1" ]; }  # $1 >= $2 ?

installed="$(defaults read "$APP/Contents/Info" CFBundleShortVersionString 2>/dev/null || echo 0.0.0)"

tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
curl -fsSL "$API" -o "$tmp/rel.json" || { echo "リリース取得失敗"; exit 0; }
tag="$(plutil -extract tag_name raw -o - "$tmp/rel.json" 2>/dev/null || echo "")"
latest="${tag#v}"
url="$(plutil -extract assets.0.browser_download_url raw -o - "$tmp/rel.json" 2>/dev/null || echo "")"
[ -n "$latest" ] || { echo "リリースなし"; exit 0; }

if ver_ge "$installed" "$latest"; then
  echo "最新です (installed=$installed, latest=$latest)"
  [ "$MODE" = "--check" ] && notify "keystats" "最新です ($installed)"
  exit 0
fi

echo "更新あり: $installed → $latest"
[ "$MODE" = "--check" ] && { notify "keystats" "新しいバージョン $latest があります"; exit 10; }

[ -n "$url" ] || { echo "配布URLなし"; exit 1; }
echo "DL: $url"
curl -fsSL "$url" -o "$tmp/pkg.zip"
ditto -x -k "$tmp/pkg.zip" "$tmp/x"
new="$(find "$tmp/x" -maxdepth 3 -name Keystats.app -type d | head -1)"
[ -n "$new" ] || { echo "新Keystats.appが見つかりません"; exit 1; }
xattr -dr com.apple.quarantine "$new" 2>/dev/null || true

echo "差し替え: $APP"
rm -rf "$APP"; cp -R "$new" "$APP"          # 実行中でも inode は生きるので安全

uid="$(id -u)"
# 旧 daemon / GUI を止めてから新アプリを起動する。アプリが起動時に daemon/gui/update の
# LaunchAgent を自己登録し直す(plist が消えていても再生成される = 堅い)。
launchctl bootout "gui/$uid/net.gapul.keystats"     2>/dev/null || true
launchctl bootout "gui/$uid/net.gapul.keystats.gui" 2>/dev/null || true
pkill -f "Keystats.app/Contents/MacOS/KeystatsGUI"  2>/dev/null || true
sleep 1
open -g "$APP"                               # -g: 前面に出さずに起動 → 自己ブートストラップ

echo "更新完了: $latest"
notify "keystats" "$latest に更新しました"
